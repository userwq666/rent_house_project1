# EditorConfig helps maintain consistent coding styles
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,ts,vue,json,css,scss,md}]
indent_style = space
indent_size = 2

[*.{java,xml,properties}]
indent_style = space
indent_size = 4
